---
import "../styles/global.css";

const CHROME_STORE_URL = "https://chromewebstore.google.com/detail/xray/hhjeldidbpndgbkhlkekngfjmoedemnk";
const GITHUB_URL = "https://github.com/ibrahemid/xray";

const browsers = [
  { name: "Chrome", url: CHROME_STORE_URL },
  { name: "Arc", url: CHROME_STORE_URL },
  { name: "Brave", url: CHROME_STORE_URL },
  { name: "Edge", url: CHROME_STORE_URL },
  { name: "Vivaldi", url: CHROME_STORE_URL },
  { name: "Opera", url: CHROME_STORE_URL },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="alternate icon" type="image/svg+xml" href="/icon.svg" />
    <meta name="theme-color" content="#0a84ff" />

    <title>Xray — One click. Every element outlined.</title>
    <meta
      name="description"
      content="A browser extension that outlines every element on the page so you can see the box model at a glance. One click on, one click off. No popup. No settings."
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://xray.ibrahemid.com" />
    <meta property="og:title" content="Xray — One click. Every element outlined." />
    <meta
      property="og:description"
      content="See the box model of any page at a glance. One click on, one click off."
    />
    <meta property="og:image" content="https://xray.ibrahemid.com/screenshots/on.jpg" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Xray — One click. Every element outlined." />
    <meta
      name="twitter:description"
      content="See the box model of any page at a glance. One click on, one click off."
    />
    <meta name="twitter:image" content="https://xray.ibrahemid.com/screenshots/on.jpg" />

    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="min-h-screen antialiased">
    <div class="fixed inset-x-0 top-0 h-px bg-[var(--color-line)] z-50"></div>

    <header
      class="sticky top-0 z-40 backdrop-blur bg-[color:rgb(250_250_250_/_0.7)] border-b border-[var(--color-line)]"
    >
      <div
        class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between"
      >
        <a href="/" class="flex items-center gap-2 font-mono font-medium">
          <img src="/icon.svg" alt="" width="22" height="22" />
          <span>xray</span>
        </a>
        <nav class="flex items-center gap-1 text-sm">
          <a
            href={GITHUB_URL}
            class="px-3 py-1.5 rounded-md text-neutral-600 hover:text-[var(--color-ink)] hover:bg-black/5 transition"
          >GitHub</a>
          <a
            href={CHROME_STORE_URL}
            class="ml-2 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md bg-[var(--color-ink)] text-white text-sm font-medium hover:bg-black/80 transition"
          >
            Install
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M8 7h9v9"/></svg>
          </a>
        </nav>
      </div>
    </header>

    <main>
      <section class="relative">
        <div
          class="absolute inset-0 -z-10 opacity-[0.04] [background-image:linear-gradient(to_right,#000_1px,transparent_1px),linear-gradient(to_bottom,#000_1px,transparent_1px)] [background-size:32px_32px]"
          aria-hidden="true"
        ></div>

        <div class="max-w-6xl mx-auto px-6 pt-20 pb-16 md:pt-28 md:pb-24">
          <div class="max-w-3xl">
            <div
              class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--color-line)] bg-white/60 backdrop-blur text-xs font-mono text-neutral-600 mb-8"
            >
              <span class="size-1.5 rounded-full bg-[var(--color-blue)]"></span>
              v1.0 — free, MIT licensed
            </div>

            <h1
              class="font-display text-[clamp(2.5rem,6vw,5rem)] leading-[0.95] tracking-[-0.04em] font-bold"
            >
              One click.
              <br />
              <span class="relative inline-block">
                <span class="relative z-10">Every element</span>
                <span
                  class="absolute inset-0 -z-0 translate-y-[0.55em] h-[0.18em] bg-[var(--color-blue)]/30"
                  aria-hidden="true"
                ></span>
              </span>
              <br />
              outlined.
            </h1>

            <p
              class="mt-8 text-lg md:text-xl text-neutral-600 max-w-2xl leading-relaxed"
            >
              A browser extension that shows the box model of any page at a
              glance. Click the icon, every element outlined. Click again, gone.
              <span class="text-[var(--color-ink)] font-medium"
                >No popup. No settings. No modal.</span
              >
            </p>

            <div class="mt-10 flex flex-wrap items-center gap-3">
              <a
                href={CHROME_STORE_URL}
                class="group inline-flex items-center gap-2.5 px-5 py-3 rounded-lg bg-[var(--color-ink)] text-white font-medium hover:bg-black/85 transition shadow-[0_8px_30px_-12px_rgba(0,0,0,0.4)]"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                  <path d="M12 6a6 6 0 1 0 5.19 9H12V6z"/>
                </svg>
                Add to Chrome
                <span
                  class="text-xs font-mono opacity-70 group-hover:opacity-100 transition"
                  >→</span
                >
              </a>
              <a
                href={GITHUB_URL}
                class="inline-flex items-center gap-2 px-5 py-3 rounded-lg border border-[var(--color-line)] bg-white/60 backdrop-blur font-medium hover:bg-white transition"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.23A11.5 11.5 0 0 1 12 5.8c1.02 0 2.05.14 3.01.4 2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.24 2.87.12 3.17.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.82 1.1.82 2.22 0 1.6-.02 2.89-.02 3.29 0 .32.22.7.83.58A12 12 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                View source
              </a>
            </div>

            <p class="mt-6 text-sm text-neutral-500 font-mono">
              Works on any Chromium browser →
              <span class="text-neutral-700">Chrome · Arc · Brave · Edge · Vivaldi · Opera</span>
            </p>
          </div>
        </div>
      </section>

      <section class="border-y border-[var(--color-line)] bg-white">
        <div class="max-w-6xl mx-auto px-6 py-16 md:py-24">
          <div class="flex items-baseline justify-between mb-10 gap-6 flex-wrap">
            <div>
              <p class="font-mono text-xs uppercase tracking-widest text-[var(--color-blue)]">
                Before / After
              </p>
              <h2 class="mt-2 text-3xl md:text-4xl font-bold tracking-tight">
                One click flips it.
              </h2>
            </div>
            <p class="text-neutral-500 max-w-md text-sm md:text-base">
              Same Wikipedia page. Click the icon and every box, padding, and
              outline becomes visible. Click again and you're back.
            </p>
          </div>

          <div class="grid md:grid-cols-2 gap-4 md:gap-6">
            <figure class="group">
              <div
                class="relative overflow-hidden rounded-xl border border-[var(--color-line)] bg-neutral-50 aspect-[16/10]"
              >
                <img
                  src="/screenshots/off.jpg"
                  alt="Wikipedia page with Xray off — normal rendering"
                  class="absolute inset-0 w-full h-full object-cover object-top"
                  loading="eager"
                  decoding="async"
                />
                <div
                  class="absolute top-3 left-3 px-2.5 py-1 rounded-md bg-white/95 backdrop-blur text-xs font-mono font-medium border border-[var(--color-line)]"
                >
                  off
                </div>
              </div>
              <figcaption
                class="mt-3 font-mono text-xs text-neutral-500 flex items-center gap-2"
              >
                <span class="size-1.5 rounded-full bg-neutral-300"></span>
                Default rendering
              </figcaption>
            </figure>

            <figure class="group">
              <div
                class="relative overflow-hidden rounded-xl border border-[var(--color-blue)]/30 bg-neutral-50 aspect-[16/10] ring-1 ring-[var(--color-blue)]/10"
              >
                <img
                  src="/screenshots/on.jpg"
                  alt="Wikipedia page with Xray on — every element outlined in blue"
                  class="absolute inset-0 w-full h-full object-cover object-top"
                  loading="eager"
                  decoding="async"
                />
                <div
                  class="absolute top-3 left-3 px-2.5 py-1 rounded-md bg-[var(--color-blue)] text-white text-xs font-mono font-medium"
                >
                  on
                </div>
              </div>
              <figcaption
                class="mt-3 font-mono text-xs text-neutral-500 flex items-center gap-2"
              >
                <span class="size-1.5 rounded-full bg-[var(--color-blue)]"></span>
                Every element outlined
              </figcaption>
            </figure>
          </div>
        </div>
      </section>

      <section class="bg-white">
        <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
          <div class="flex items-baseline justify-between flex-wrap gap-6 mb-10">
            <div>
              <p class="font-mono text-xs uppercase tracking-widest text-[var(--color-blue)]">
                Install
              </p>
              <h2 class="mt-2 text-3xl md:text-4xl font-bold tracking-tight">
                Pick your browser.
              </h2>
            </div>
            <p class="text-sm text-neutral-500 font-mono">
              Single listing on the Chrome Web Store — installs on all
              Chromium browsers.
            </p>
          </div>

          <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
            {browsers.map((b) => (
              <li>
                <a
                  href={b.url}
                  class="group block p-5 rounded-xl border border-[var(--color-line)] bg-white hover:border-[var(--color-ink)]/30 hover:-translate-y-0.5 transition"
                >
                  <div class="font-medium">{b.name}</div>
                  <div
                    class="mt-1 text-xs font-mono text-neutral-500 group-hover:text-[var(--color-ink)] transition"
                  >
                    install →
                  </div>
                </a>
              </li>
            ))}
          </ul>

          <div
            class="mt-10 p-6 rounded-xl border border-dashed border-[var(--color-line)] bg-neutral-50"
          >
            <p class="font-mono text-xs uppercase tracking-widest text-neutral-500">
              Or load unpacked
            </p>
            <ol class="mt-3 space-y-1.5 text-sm text-neutral-700 font-mono">
              <li>
                1.{" "}
                <code class="bg-white px-1.5 py-0.5 rounded border border-[var(--color-line)]"
                  >chrome://extensions</code
                >
              </li>
              <li>2. Enable Developer mode</li>
              <li>3. Load unpacked → select the <code class="bg-white px-1.5 py-0.5 rounded border border-[var(--color-line)]">extension/</code> folder</li>
            </ol>
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-[var(--color-line)]">
      <div
        class="max-w-6xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-sm text-neutral-500"
      >
        <div class="flex items-center gap-2 font-mono">
          <img src="/icon.svg" alt="" width="18" height="18" />
          <span>xray</span>
          <span class="text-neutral-300">·</span>
          <span>MIT</span>
        </div>
        <div class="flex items-center gap-5">
          <a href="/privacy" class="hover:text-[var(--color-ink)] transition">Privacy</a>
          <a href={GITHUB_URL} class="hover:text-[var(--color-ink)] transition">GitHub</a>
          <a href="https://ibrahemid.com" class="hover:text-[var(--color-ink)] transition">
            by ibrahemid
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
