---
import "../styles/global.css";

const LAST_UPDATED = "May 14, 2026";
const CONTACT_EMAIL = "ibrahemid@gmail.com";
const GITHUB_URL = "https://github.com/ibrahemid/xray";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="alternate icon" type="image/svg+xml" href="/icon.svg" />
    <meta name="theme-color" content="#0a84ff" />
    <meta name="robots" content="index, follow" />

    <title>Privacy Policy — Xray</title>
    <meta
      name="description"
      content="Xray collects no data. No tracking, no analytics, no network requests, no storage. This page explains exactly what that means."
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="min-h-screen antialiased">
    <header
      class="sticky top-0 z-40 backdrop-blur bg-[color:rgb(250_250_250_/_0.7)] border-b border-[var(--color-line)]"
    >
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-mono font-medium">
          <img src="/icon.svg" alt="" width="22" height="22" />
          <span>xray</span>
        </a>
        <nav class="flex items-center gap-1 text-sm">
          <a
            href="/"
            class="px-3 py-1.5 rounded-md text-neutral-600 hover:text-[var(--color-ink)] hover:bg-black/5 transition"
            >Home</a
          >
          <a
            href={GITHUB_URL}
            class="px-3 py-1.5 rounded-md text-neutral-600 hover:text-[var(--color-ink)] hover:bg-black/5 transition"
            >GitHub</a
          >
        </nav>
      </div>
    </header>

    <main>
      <section class="border-b border-[var(--color-line)]">
        <div class="max-w-3xl mx-auto px-6 py-16 md:py-20">
          <p
            class="font-mono text-xs uppercase tracking-widest text-[var(--color-blue)]"
          >
            Privacy Policy
          </p>
          <h1
            class="mt-3 text-4xl md:text-5xl font-bold tracking-[-0.03em]"
          >
            Xray collects nothing.
          </h1>
          <p class="mt-6 text-lg text-neutral-600 leading-relaxed">
            No tracking. No analytics. No telemetry. No network requests. No
            storage. No accounts. No cookies. No data leaves your browser.
          </p>
          <p class="mt-3 text-sm font-mono text-neutral-500">
            Last updated: {LAST_UPDATED}
          </p>
        </div>
      </section>

      <section class="bg-white">
        <div
          class="max-w-3xl mx-auto px-6 py-16 md:py-20 prose-content"
        >
          <h2 class="text-2xl font-bold tracking-tight">What Xray does</h2>
          <p class="mt-4 text-neutral-700 leading-relaxed">
            Xray is a Chromium browser extension. When you click its toolbar
            icon on a webpage, it injects a small CSS rule into that page that
            outlines every element so you can see the box model at a glance.
            When you click the icon again, it removes that CSS rule.
          </p>
          <p class="mt-3 text-neutral-700 leading-relaxed">
            That is the entire extension.
          </p>

          <h2 class="mt-12 text-2xl font-bold tracking-tight">
            Data we collect
          </h2>
          <p class="mt-4 text-neutral-700 leading-relaxed">
            None. Specifically, Xray does not collect, store, transmit, sell,
            share, or process any of the following:
          </p>
          <ul class="mt-4 space-y-2 text-neutral-700">
            <li class="flex gap-3">
              <span class="font-mono text-[var(--color-blue)]">—</span>
              <span>Personally identifiable information (name, email, ID, age)</span>
            </li>
            <li class="flex gap-3">
              <span class="font-mono text-[var(--color-blue)]">—</span>
              <span>Health information</span>
            </li>
            <li class="flex gap-3">
              <span class="font-mono text-[var(--color-blue)]">—</span>
              <span>Financial or payment information</span>
            </li>
            <li class="flex gap-3">
              <span class="font-mono text-[var(--color-blue)]">—</span>
              <span>Authentication credentials (passwords, tokens, PINs)</span>
            </li>
            <li class="flex gap-3">
              <span class="font-mono text-[var(--color-blue)]">—</span>
              <span>Personal communications (email, chat, SMS)</span>
            </li>
            <li class="flex gap-3">
              <span class="font-mono text-[var(--color-blue)]">—</span>
              <span>Location (region, IP address, GPS)</span>
            </li>
            <li class="flex gap-3">
              <span class="font-mono text-[var(--color-blue)]">—</span>
              <span>Web browsing history</span>
            </li>
            <li class="flex gap-3">
              <span class="font-mono text-[var(--color-blue)]">—</span>
              <span>User activity (clicks, scrolls, keystrokes, mouse position)</span>
            </li>
            <li class="flex gap-3">
              <span class="font-mono text-[var(--color-blue)]">—</span>
              <span>Website content (text, images, hyperlinks, media)</span>
            </li>
          </ul>

          <h2 class="mt-12 text-2xl font-bold tracking-tight">
            Permissions and why they exist
          </h2>
          <p class="mt-4 text-neutral-700 leading-relaxed">
            The extension declares two Chrome permissions in its manifest:
          </p>
          <div
            class="mt-4 p-5 rounded-xl border border-[var(--color-line)] bg-neutral-50 font-mono text-sm"
          >
            <div>
              <span class="text-[var(--color-blue)]">activeTab</span> — used
              only when you click the toolbar icon, and only on the tab that is
              active at that moment.
            </div>
            <div class="mt-3">
              <span class="text-[var(--color-blue)]">scripting</span> — used to
              execute the bundled toggle function on the active tab. The
              function adds or removes a <code>{`<style>`}</code> element. It does not
              read page content.
            </div>
          </div>

          <h2 class="mt-12 text-2xl font-bold tracking-tight">
            No remote code
          </h2>
          <p class="mt-4 text-neutral-700 leading-relaxed">
            Xray does not fetch, download, evaluate, or execute any code from
            the network. The toggle function is bundled inside the extension
            package and passed to <code class="font-mono text-sm bg-neutral-100 px-1 py-0.5 rounded">chrome.scripting.executeScript</code> by
            function reference. There is no <code class="font-mono text-sm bg-neutral-100 px-1 py-0.5 rounded">eval</code>, no dynamic
            <code class="font-mono text-sm bg-neutral-100 px-1 py-0.5 rounded">import</code>, no remote script tag, no remote configuration, and
            no remote rules.
          </p>

          <h2 class="mt-12 text-2xl font-bold tracking-tight">
            No network activity
          </h2>
          <p class="mt-4 text-neutral-700 leading-relaxed">
            The extension makes zero network requests at runtime. It does not
            phone home, does not check for updates outside the standard Chrome
            Web Store auto-update mechanism, and does not communicate with any
            third-party service.
          </p>

          <h2 class="mt-12 text-2xl font-bold tracking-tight">
            No storage
          </h2>
          <p class="mt-4 text-neutral-700 leading-relaxed">
            The extension uses no <code class="font-mono text-sm bg-neutral-100 px-1 py-0.5 rounded">chrome.storage</code>, no
            <code class="font-mono text-sm bg-neutral-100 px-1 py-0.5 rounded">localStorage</code>, no <code class="font-mono text-sm bg-neutral-100 px-1 py-0.5 rounded">IndexedDB</code>, and no cookies. There
            is no setting to persist because there is no setting.
          </p>

          <h2 class="mt-12 text-2xl font-bold tracking-tight">
            Children's privacy
          </h2>
          <p class="mt-4 text-neutral-700 leading-relaxed">
            Since the extension does not collect any data, no special handling
            is required for users under 13. The extension is safe for all
            ages.
          </p>

          <h2 class="mt-12 text-2xl font-bold tracking-tight">
            Open source
          </h2>
          <p class="mt-4 text-neutral-700 leading-relaxed">
            The entire source of the extension is published on GitHub under
            the MIT license. You can verify every claim on this page by reading
            the code:
            <a
              href={GITHUB_URL}
              class="text-[var(--color-blue)] underline underline-offset-2 hover:no-underline"
              >{GITHUB_URL}</a
            >
          </p>

          <h2 class="mt-12 text-2xl font-bold tracking-tight">
            Changes to this policy
          </h2>
          <p class="mt-4 text-neutral-700 leading-relaxed">
            If the extension's behavior ever changes in a way that affects
            this policy, this page will be updated and the "last updated" date
            at the top revised. Material changes will be announced in the
            extension's release notes on the Chrome Web Store.
          </p>

          <h2 class="mt-12 text-2xl font-bold tracking-tight">Contact</h2>
          <p class="mt-4 text-neutral-700 leading-relaxed">
            Privacy questions, concerns, or requests:
            <a
              href={`mailto:${CONTACT_EMAIL}`}
              class="text-[var(--color-blue)] underline underline-offset-2 hover:no-underline"
              >{CONTACT_EMAIL}</a
            >
          </p>
        </div>
      </section>
    </main>

    <footer class="border-t border-[var(--color-line)]">
      <div
        class="max-w-6xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-sm text-neutral-500"
      >
        <div class="flex items-center gap-2 font-mono">
          <img src="/icon.svg" alt="" width="18" height="18" />
          <span>xray</span>
          <span class="text-neutral-300">·</span>
          <span>MIT</span>
        </div>
        <div class="flex items-center gap-5">
          <a href="/" class="hover:text-[var(--color-ink)] transition">Home</a>
          <a href={GITHUB_URL} class="hover:text-[var(--color-ink)] transition">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
